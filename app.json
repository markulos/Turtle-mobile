{
  "expo": {
    "name": "PasswordTaskManager",
    "slug": "password-task-manager",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourcompany.passwordtaskmanager",
      "infoPlist": {
        "NSFaceIDUsageDescription": "This app uses Face ID to securely unlock your passwords.",
        "NSBiometricUsageDescription": "This app uses biometric authentication to protect your passwords."
      }
    },
    "android": {
      "package": "com.yourcompany.passwordtaskmanager",
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "plugins": [
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow $(PRODUCT_NAME) to use Face ID to unlock your passwords."
        }
      ],
      "expo-video",
      "expo-secure-store"
    ]
  }
}
